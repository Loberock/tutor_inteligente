{
  "info": {
    "name": "TutorInteligente API",
    "description": "Coleccion base para probar autenticacion, cursos, preguntas, evaluaciones y reportes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "profesorId",
      "value": "1"
    },
    {
      "key": "alumnoId",
      "value": "1"
    },
    {
      "key": "cursoId",
      "value": "1"
    },
    {
      "key": "preguntaId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar profesor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/usuarios",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ada\",\n  \"apellido\": \"Lovelace\",\n  \"correo\": \"profesor@test.com\",\n  \"contrasena\": \"123456\",\n  \"tipo\": \"PROFESOR\"\n}"
            }
          }
        },
        {
          "name": "Registrar alumno",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/usuarios",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Alan\",\n  \"apellido\": \"Turing\",\n  \"correo\": \"alumno@test.com\",\n  \"contrasena\": \"123456\",\n  \"grado\": \"1\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/sesiones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"profesor@test.com\",\n  \"contrasena\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Cursos",
      "item": [
        {
          "name": "Listar cursos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/cursos"
          }
        },
        {
          "name": "Crear curso",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/cursos",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombreCurso\": \"Matematica\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Preguntas",
      "item": [
        {
          "name": "Crear pregunta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/preguntas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profesorId\": {{profesorId}},\n  \"cursoId\": {{cursoId}},\n  \"contenidoPregunta\": \"Cuanto es 2 + 2?\",\n  \"grado\": \"1\",\n  \"dificultad\": \"BASICO\",\n  \"opcionA\": \"3\",\n  \"opcionB\": \"4\",\n  \"opcionC\": \"5\",\n  \"opcionD\": \"6\",\n  \"respuestaCorrecta\": \"B\",\n  \"refuerzo\": \"Repasa la suma de numeros naturales.\"\n}"
            }
          }
        },
        {
          "name": "Listar preguntas con filtros",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/preguntas?cursoId={{cursoId}}&grado=1&dificultad=BASICO"
          }
        }
      ]
    },
    {
      "name": "Evaluaciones",
      "item": [
        {
          "name": "Obtener diagnostico",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/evaluaciones/diagnostico?cursoId={{cursoId}}&grado=1&nivel=BASICO&cantidad=10"
          }
        },
        {
          "name": "Procesar evaluacion",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/evaluaciones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alumnoId\": {{alumnoId}},\n  \"respuestas\": [\n    {\n      \"preguntaId\": {{preguntaId}},\n      \"respuestaSeleccionada\": \"B\"\n    }\n  ],\n  \"cursos\": [\n    {\n      \"cursoId\": {{cursoId}},\n      \"nivel\": \"BASICO\"\n    }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reportes",
      "item": [
        {
          "name": "Rendimiento",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/reportes/rendimiento"
          }
        },
        {
          "name": "Refuerzos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/v1/reportes/refuerzos"
          }
        }
      ]
    }
  ]
}
